<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.green.momoolggo.application.cart.CartMapper">

    <!-- menuId로 storeId 조회 (menu → menu_category 조인) -->
    <select id="findStoreIdByMenuId" resultType="Long">
        SELECT mc.store_id
        FROM menu m
                 JOIN menu_category mc ON m.category_id = mc.category_id
        WHERE m.menu_id = #{menuId}
    </select>

    <!-- userNo로 장바구니 조회 -->
    <select id="findCartByUserNo" resultType="com.green.momoolggo.application.cart.model.Cart">
        SELECT cart_id, user_no, store_id
        FROM cart
        WHERE user_no = #{userNo}
            LIMIT 1
    </select>

    <!-- 장바구니 생성 -->
    <insert id="insertCart">
        INSERT INTO cart (user_no, store_id)
        VALUES (#{userNo}, #{storeId})
    </insert>

    <!-- 마지막 cart_id 조회 -->
    <select id="getLastCartId" resultType="Long">
        SELECT LAST_INSERT_ID()
    </select>

    <!-- 장바구니 아이템 추가 -->
    <insert id="insertCartItem">
        INSERT INTO cart_detail (cart_id, menu_id, quantity)
        VALUES (#{cartId}, #{menuId}, #{quantity})
    </insert>

    <!-- 장바구니 아이템 전체 삭제 -->
    <delete id="deleteAllCartItems">
        DELETE FROM cart_detail
        WHERE cart_id = #{cartId}
    </delete>

    <!-- 장바구니 삭제 -->
    <delete id="deleteCart">
        DELETE FROM cart
        WHERE cart_id = #{cartId}
    </delete>

</mapper>